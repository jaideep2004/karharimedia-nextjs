{
  "name": "nextjs-karharimedia",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    ".",
    "server"
  ],
  "scripts": {
    "dev:client": "next dev",
    "dev:server": "cd server && npm run dev",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "build:client": "next build",
    "build:server": "cd server && npm run build",
    "build": "npm run build:client && npm run build:server",
    "start:client": "next start",
    "start:server": "cd server && npm run start",
    "start": "concurrently \"npm run start:client\" \"npm run start:server\"",
    "lint:client": "eslint src --ext .ts,.tsx",
    "lint:server": "cd server && npm run lint",
    "lint": "npm run lint:client && npm run lint:server",
    "install:server": "cd server && npm install",
    "db:migrate:preflight": "node scripts/production-db-migration.mjs preflight",
    "db:tracks:backfill:dry-run": "node scripts/production-db-migration.mjs tracks-backfill",
    "db:tracks:backfill": "node scripts/production-db-migration.mjs tracks-backfill --write",
    "db:ownership:backfill:dry-run": "node scripts/production-db-migration.mjs ownership-backfill",
    "db:ownership:backfill": "node scripts/production-db-migration.mjs ownership-backfill --write",
    "db:orgs:backfill:dry-run": "node scripts/production-db-migration.mjs orgs-backfill",
    "db:orgs:backfill": "node scripts/production-db-migration.mjs orgs-backfill --write",
    "db:track-assets:backfill:dry-run": "node scripts/production-db-migration.mjs track-assets-backfill",
    "db:track-assets:backfill": "node scripts/production-db-migration.mjs track-assets-backfill --write",
    "db:track-fingerprints:backfill:dry-run": "node scripts/production-db-migration.mjs track-fingerprints-backfill",
    "db:track-fingerprints:backfill": "node scripts/production-db-migration.mjs track-fingerprints-backfill --write",
    "db:parity:tracks": "node scripts/production-db-migration.mjs parity-tracks",
    "db:parity:ownership": "node scripts/production-db-migration.mjs parity-ownership",
    "db:legacy-release-tracks:cleanup:dry-run": "node scripts/production-db-migration.mjs legacy-release-tracks-cleanup",
    "db:legacy-release-tracks:cleanup": "node scripts/production-db-migration.mjs legacy-release-tracks-cleanup --write",
    "db:indexes:create:dry-run": "node scripts/production-db-migration.mjs indexes-create",
    "db:indexes:create": "node scripts/production-db-migration.mjs indexes-create --write"
  },
  "dependencies": {
    "@auth/core": "^0.40.0",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.14.1",
    "@floating-ui/dom": "^1.7.6",
    "@fortawesome/fontawesome-free": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.0",
    "@mui/icons-material": "^7.2.0",
    "@mui/material": "^7.2.0",
    "@mui/x-data-grid": "^8.8.0",
    "@mui/x-date-pickers": "^8.8.0",
    "@tiptap/extension-image": "^3.23.6",
    "@tiptap/extension-link": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/extension-table": "^3.23.6",
    "@tiptap/extension-underline": "^3.23.6",
    "@tiptap/extension-youtube": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@types/next-auth": "^3.15.0",
    "archiver": "^8.0.0",
    "axios": "^1.10.0",
    "dayjs": "^1.11.13",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.23.24",
    "js-cookie": "^3.0.5",
    "jwt-decode": "^4.0.0",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.29",
    "react": "^19.2.6",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.60.0",
    "recharts": "^3.1.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/archiver": "^7.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^8.2.2",
    "eslint": "^9",
    "eslint-config-next": "15.4.1",
    "typescript": "^5"
  }
}
